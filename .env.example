# =============================================================================
# Elderly Companion AI — example environment file
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in values as needed:
#
#     cp .env.example .env
#
# The committed demo defaults run fully offline: no paid API keys required.
# Keep DEMO_MODE=true and all providers on fake/mock to run the demo locally.
# Never commit a real `.env` or any real API keys (see .gitignore).
# =============================================================================

# --- Runtime -----------------------------------------------------------------
APP_ENV=development
DEMO_MODE=true
LOG_LEVEL=info
APP_TIMEZONE=Asia/Hong_Kong  # IANA timezone used for Guardian quiet hours

# --- Providers ---------------------------------------------------------------
# fake/mock providers are the default so the demo never calls paid APIs.
# Real LLM / ASR / TTS only activate when DEMO_MODE=false AND the provider is
# named below AND OPENAI_API_KEY is set; otherwise the offline fake/mock are used.
LLM_PROVIDER=fake          # fake | xiaomimimo  (xiaomimimo = real companion replies)
ASR_PROVIDER=mock          # mock | xiaomimimo
TTS_PROVIDER=mock          # mock | xiaomimimo
RETRIEVAL_PROVIDER=mock    # mock | open_meteo  (open_meteo = real weather, free, no key)

# Real weather/air-quality retrieval (Open-Meteo, free, no key). Set the demo's
# city; default is Hong Kong. Only used when DEMO_MODE=false + open_meteo above.
# RETRIEVAL_LAT=22.3193
# RETRIEVAL_LON=114.1694
# RETRIEVAL_LOCATION=香港

# Real voice/LLM provider (xiaomimimo, OpenAI-compatible endpoint). Defaults
# match the code; override only if needed. Runs through /chat/completions.
OPENAI_BASE_URL=https://api.xiaomimimo.com/v1
LLM_MODEL=mimo-v2.5         # xiaomimimo v2 is unsupported; use v2.5 by default
# ASR_MODEL=mimo-v2.5-asr
# TTS_MODEL=mimo-v2.5-tts
# TTS_VOICE=mimo_default

# --- API keys (leave empty in committed file) --------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
WEATHER_API_KEY=

# --- Storage -----------------------------------------------------------------
DATABASE_URL=sqlite:///./data/app.db
MEMORY_ROOT=./data/memory
TRACE_LOG_DIR=./data/traces
AUDIO_CACHE_DIR=./data/audio_cache

# --- Safety and budget controls ----------------------------------------------
MAX_LLM_CALLS_PER_TURN=2
MAX_WEB_CALLS_PER_TURN=1
SAFETY_CRITIC_ON_LOW_RISK=false
ENABLE_REAL_EMERGENCY_CALL=false

# --- Proactive care defaults -------------------------------------------------
PROACTIVE_ENABLED=true
PROACTIVE_MAX_CHECKINS_PER_DAY=3
PROACTIVE_SAME_TOPIC_COOLDOWN_MINUTES=120
PROACTIVE_REFUSAL_PAUSE_HOURS=24
QUIET_HOURS_START=22:00
QUIET_HOURS_END=07:00

# --- Frontend ----------------------------------------------------------------
# Base URL the Next.js frontend uses to reach the FastAPI backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Research-only evaluation export is hidden from coursework delivery by default.
# Enable it explicitly for later study sessions; the demo checklist stays hidden.
NEXT_PUBLIC_SHOW_RESEARCH_UI=false
